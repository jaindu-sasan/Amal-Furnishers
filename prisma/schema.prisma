generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  MADE_TO_ORDER
}

enum MessageStatus {
  READ
  UNREAD
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@map("adminuser")
}

model Category {
  id        String         @id @default(cuid())
  name      String
  slug      String         @unique
  status    CategoryStatus @default(ACTIVE)
  products  Product[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status])
  @@index([name])
  @@map("category")
}

model Product {
  id               String      @id @default(cuid())
  name             String
  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  productCode      String      @unique
  price            Decimal     @db.Decimal(10, 2)
  stockStatus      StockStatus
  shortDescription String      @db.VarChar(300)
  fullDescription  String      @db.Text
  imageUrl         String?
  messages         Message[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([categoryId])
  @@index([name])
  @@index([stockStatus])
  @@map("product")
}

model Message {
  id           String        @id @default(cuid())
  customerName String
  phone        String
  email        String
  message      String        @db.Text
  productId    String?
  product      Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  status       MessageStatus @default(UNREAD)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([productId])
  @@index([email])
  @@map("message")
}